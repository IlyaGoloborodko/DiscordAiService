# Copy to .env and fill in. .env is gitignored; this file is the checked-in template.

# --- AI provider (text model, OpenAI-compatible; e.g. LM Studio) ---
TM_BASE_URL=http://127.0.0.1:1234/v1
TM_API_KEY=not-needed
TM_MODEL_NAME=qwen/qwen3.5-9b

# --- Bot persona ---
## Language the bot writes/speaks (chat + TTS). Must match the TTS voice language.
BOT_LANGUAGE=English
## Bot persona name, and the forms the user addresses it by (name + declensions/nicknames), comma-separated.
BOT_NAME=Marina
BOT_NAME_FORMS=Марина,Марин,Маринка,Мариша,marina

# --- Text-to-speech (OpenAI Audio API, gpt-4o-mini-tts) ---
## Needs a REAL OpenAI key. Separate from TM_API_KEY, but typically the same value.
## Voice: alloy/ash/coral/echo/fable/onyx/nova/sage/shimmer. Format: pcm/opus/mp3/wav/flac/aac.
TTS_API_KEY=sk-...
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=nova
TTS_FORMAT=pcm
# TTS_INSTRUCTIONS=Upbeat, friendly DJ tone.

# --- Media search-service (yt-dlp lives there) ---
SEARCH_SERVICE_URL=http://127.0.0.1:9000

# --- State: conversation memory ---
POSTGRES_DSN=postgresql://user:password@127.0.0.1:5433/discord_ai
REDIS_URL=redis://127.0.0.1:6380/0
## Max tokens of intermediate history kept (system prompt + latest message are never trimmed).
HISTORY_TOKEN_LIMIT=10000
