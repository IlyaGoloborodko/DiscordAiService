# Copy to .env and fill in. .env is gitignored; this file is the checked-in template.

# --- AI provider (text model, OpenAI-compatible; e.g. LM Studio) ---
TM_BASE_URL=http://127.0.0.1:1234/v1
TM_API_KEY=not-needed
TM_MODEL_NAME=qwen/qwen3.5-9b

# --- Bot persona ---
## Language the bot writes/speaks (chat + TTS). Must match the TTS voice language.
BOT_LANGUAGE=English
## Bot persona name, and the forms the user addresses it by (name + declensions/nicknames), comma-separated.
BOT_NAME=Marina
BOT_NAME_FORMS=Марина,Марин,Маринка,Мариша,marina
## Spoken when the model promised an action the service had to drop. Must be in BOT_LANGUAGE.
# TEXT_ACTION_FAILED=Sorry, I couldn't find anything that fits — want to try another genre or artist?

# --- Track selection ---
## Max track length in seconds. Longer search hits (hour-long "mixes"/compilations) are
## dropped: the bot treats each item as one track, so a mix becomes one un-skippable entry.
MAX_TRACK_SECONDS=600

# --- Text-to-speech (OpenAI Audio API, gpt-4o-mini-tts) ---
## Needs a REAL OpenAI key. Separate from TM_API_KEY, but typically the same value.
## Voice: alloy/ash/coral/echo/fable/onyx/nova/sage/shimmer. Format: pcm/opus/mp3/wav/flac/aac.
TTS_API_KEY=sk-...
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=nova
TTS_FORMAT=pcm
# TTS_INSTRUCTIONS=Upbeat, friendly DJ tone.

# --- Media search-service (yt-dlp lives there) ---
SEARCH_SERVICE_URL=http://127.0.0.1:9000

# --- State: conversation memory ---
POSTGRES_DSN=postgresql://user:password@127.0.0.1:5433/discord_ai
REDIS_URL=redis://127.0.0.1:6380/0
## Max tokens of intermediate history kept (system prompt + latest message are never trimmed).
HISTORY_TOKEN_LIMIT=10000
## How many recently played tracks to keep per session, for "continue the previous
## playlist". A short tail, not a play history — the Discord bot loses its queue on restart.
RECENT_TRACKS_LIMIT=60

## --- Recommendations ---
## How long a track rests before it can play again. The rest grows each time it
## plays: 6h, then 12h, then 24h... capped, so a favourite is never banned forever.
PLAY_COOLDOWN_BASE_HOURS=6
PLAY_COOLDOWN_GROWTH=2.0
PLAY_COOLDOWN_MAX_HOURS=336
## Search returns the same list every time, so we fetch a bigger pile and pick from it.
## CANDIDATE_RANK_BIAS: higher = stick closer to the top hits, lower = more variety.
CANDIDATE_POOL_FACTOR=4
CANDIDATE_RANK_BIAS=1.5
